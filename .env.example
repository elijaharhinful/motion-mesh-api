# ─── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ─── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=motionmesh
DB_PASSWORD=motionmesh
DB_NAME=motionmesh
DB_SSL=false                   # set to true for Neon / managed Postgres in production

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=motionmesh

# ─── JWT RS256 ───────────────────────────────────────
JWT_SECRET=this-is-a-long-string-of-words-as-key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Storage (MinIO / AWS S3) ──────────────────────────────────────────────────
STORAGE_PROVIDER=minio
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=motionmesh
S3_SECRET_KEY=motionmesh_secret
S3_BUCKET_VIDEOS=motionmesh-videos
S3_BUCKET_GENERATIONS=motionmesh-generations
S3_PRESIGNED_URL_TTL_SECONDS=1800

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
PLATFORM_COMMISSION_PERCENT=30

# ─── Kling AI ──────────────────────────────────────────────────────────────────
KLING_API_KEY=REPLACE_ME
KLING_API_BASE_URL=https://api.klingai.com

# ─── Email / Notifications ─────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=REPLACE_ME
SMTP_PASS=REPLACE_ME
EMAIL_FROM="MotionMesh <no-reply@motionmesh.com>"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ─── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001

# ─── Video Retention ───────────────────────────────────────────────────────────
VIDEO_RETENTION_DAYS=90
