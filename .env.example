# ─── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ─── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=motionmesh
DB_PASSWORD=motionmesh
DB_NAME=motionmesh
DB_SSL=false                   # set to true for Neon / managed Postgres in production
DB_LOGGING=false               # set to true to log SQL queries (noisy — for debugging only)

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=motionmesh

# ─── JWT RS256 ───────────────────────────────────────
JWT_SECRET=this-is-a-long-string-of-words-as-key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Storage (Cloudflare R2) ─────────────────────────────────────────────────────
# R2 is S3-compatible. Endpoint = https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Region MUST be "auto". Access key/secret come from an R2 API token
# (Cloudflare dashboard → R2 → Manage API Tokens → Object Read & Write).
# For local MinIO instead: STORAGE_PROVIDER=minio, S3_ENDPOINT=http://localhost:9000,
# S3_REGION=us-east-1, and the MinIO key/secret.
# Single bucket; assets are separated by key prefix (videos/ uploads/ generations/ avatars/).
STORAGE_PROVIDER=r2
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY=<R2_ACCESS_KEY_ID>
S3_SECRET_KEY=<R2_SECRET_ACCESS_KEY>
S3_BUCKET=motion-mesh
S3_PRESIGNED_URL_TTL_SECONDS=1800

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
PLATFORM_COMMISSION_PERCENT=30

# ─── Kling AI ──────────────────────────────────────────────────────────────────
KLING_API_KEY=REPLACE_ME
KLING_API_BASE_URL=https://api.klingai.com

# ─── Email / Notifications ─────────────────────────────────────────────────────
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=<your gmail>,
# SMTP_PASS=<16-char App Password from Google Account > Security > App passwords
# (requires 2FA enabled). Use port 587 (STARTTLS). EMAIL_FROM should match SMTP_USER.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=REPLACE_ME
SMTP_PASS=REPLACE_ME
EMAIL_FROM="MotionMesh <REPLACE_ME@gmail.com>"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ─── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001

# ─── Video Retention ───────────────────────────────────────────────────────────
VIDEO_RETENTION_DAYS=90
